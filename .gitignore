
## `.gitignore`

```gitignore
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment variables
.env
.env.local
.env.*.local
.env.test
.env.production

# Database
*.db
*.sqlite
*.sqlite3
prisma/*.db
prisma/*.db-journal

# Prisma
# Keep Prisma migrations tracked for reproducible deployments
!prisma/migrations/
!prisma/migrations/**
prisma/seed.js
!prisma/seed.js

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo
*~

# IDE files
.vscode/
.idea/
*.sublime-*
.project
.classpath
.settings/

# Build outputs
dist/
build/
out/
*.tsbuildinfo

# Coverage directory
coverage/
.nyc_output/
*.lcov

# PM2 logs
.pm2/

# Redis dump
dump.rdb

# Temp files
tmp/
temp/
*.tmp
*.temp

# Uploads
uploads/
files/
public/uploads/

# Certificates
*.pem
*.crt
*.key
*.p12

# Secrets
.secrets/
secrets/
*.secret
*.key

# Jest
jest.config.js
!jest.config.js

# ESLint
.eslintcache

# Prettier
.prettierrc
!.prettierrc

# Docker
docker-compose.override.yml
*.dockerignore

# Backup files
*.bak
*.backup
*.old

# Archive files
*.zip
*.tar.gz
*.rar

# Memory dumps
*.heap
*.heapsnapshot
*.heapsnapshot.*

# Logs from workers
worker-out.log
worker-error.log
api-out.log
api-error.log

# Environment specific
.env.development
.env.staging
.env.production.local

# Database backups
backups/
*.backup.sql

# Session data
.sessions/

# Redis
redis-data/