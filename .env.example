# ============================================================
# SUBSCRIPTION BILLING — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ALL variables marked REQUIRED must be set or app will crash
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=production          # REQUIRED: development | test | production
PORT=3000                     # REQUIRED
LOG_LEVEL=info                # debug | info | warn | error

# ── Database ─────────────────────────────────────────────────
DATABASE_URL_LOCAL=postgresql://postgres:1234@localhost:5432/billing_db?schema=public # REQUIRED# For Prisma migrations in environments with connection pooling, set a direct URL:
# DIRECT_URL=postgresql://billing_user:billing_pass@localhost:5432/billing_db

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379   # REQUIRED

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_min_32_chars_random_secret_here   # REQUIRED — min 32 chars
JWT_EXPIRES_IN=15m                                      # REQUIRED
REFRESH_TOKEN_EXPIRES_IN=7d                             # REQUIRED
BCRYPT_ROUNDS=12                                        # REQUIRED — 10 minimum for prod

# ── Billing Engine ───────────────────────────────────────────
RECOGNITION_CRON=0 2 1 * *   # 2 AM on 1st of every month
RECOGNITION_BATCH_SIZE=100
DUNNING_RETRY_DAYS=3,7,14    # Comma-separated days after due date
DUNNING_ENABLED=true

# ── Webhooks ─────────────────────────────────────────────────
WEBHOOK_MAX_ATTEMPTS=3
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_SIGNING_SECRET=CHANGE_ME_webhook_signing_secret   # REQUIRED

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000   # 1 minute window
RATE_LIMIT_MAX_REQUESTS=100  # per tenant per window
AUTH_RATE_LIMIT_MAX=20       # stricter limit for auth routes

# ── Pagination ───────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
